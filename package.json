{
  "name": "inventory-sales-hub",
  "version": "0.0.0",
  "description": "Inventory and Sales Management Hub",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:api-server",
    "dev:api-server": "tsx watch --ignore artifacts/my-app --ignore artifacts/mockup-sandbox --ignore dist artifacts/api-server/src/index.ts",
    "dev:my-app": "vite --config artifacts/my-app/vite.config.ts",
    "dev:mockup-sandbox": "vite dev --config artifacts/mockup-sandbox/vite.config.ts",
    "build:api-server": "node ./artifacts/api-server/build.mjs",
    "build:my-app": "vite build --config artifacts/my-app/vite.config.ts",
    "build:mockup-sandbox": "vite build --config artifacts/mockup-sandbox/vite.config.ts",
    "build": "npm run typecheck && npm run build:api-server && npm run build:my-app && npm run build:mockup-sandbox",
    "start": "node dist/api-server/index.mjs",
    "typecheck": "tsc --build",
    "api-spec:codegen": "orval --config ./lib/api-spec/orval.config.ts",
    "db:push": "drizzle-kit push --config ./lib/db/drizzle.config.ts",
    "db:push-force": "drizzle-kit push --force --config ./lib/db/drizzle.config.ts",
    "hello": "tsx ./scripts/src/hello.ts"
  },
  "dependencies": {
